# Copy to .env and adjust as needed. The real .env is never committed.
#
# A fresh clone needs NO .env: the values below are the defaults baked into
# docker-compose.yml and application.yaml. This single file drives BOTH the
# PostgreSQL container and the application, so the two can never drift.

# ── PostgreSQL (shared by docker-compose.yml and the application) ──────────
POSTGRES_DB=nimba
POSTGRES_USER=nimba
POSTGRES_PASSWORD=nimba
POSTGRES_PORT=5433
# Host the application connects to. Locally this is the host-mapped container
# port (localhost); in staging/production point it at the bank's internal
# database host.
POSTGRES_HOST=localhost

# Connection pool size (application only). See application.yaml for rationale.
DB_POOL_MAX_SIZE=10

# Managed Postgres (Neon on Render, etc.): set the WHOLE JDBC connection string
# here and it is used verbatim — do NOT split it into POSTGRES_HOST/PORT. Keep only
# sslmode=require for JDBC (drop channel_binding, a psql-only option). Credentials
# still come from POSTGRES_USER / POSTGRES_PASSWORD above. Leave unset for local dev.
# DATABASE_URL=jdbc:postgresql://ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── API ────────────────────────────────────────────────────────────────────
# Prefix applied to every REST endpoint (the API version lives here only). The
# frontend's API base URL must point at this same prefix.
API_BASE_PATH=/api/v1

# ── File upload (amortization-schedule CSV) ─────────────────────────────────
# Maximum accepted size of an uploaded CSV (NIMBA-19).
CSV_UPLOAD_MAX_FILE_SIZE=2MB
# Local directory where original uploaded CSVs are retained for audit (NIMBA-20).
AMORTIZATION_SCHEDULE_STORAGE_DIR=storage/credit-cases

# ── Authentication (session cookie, NIMBA-9) ────────────────────────────────
# Send the session cookie only over HTTPS. MUST be true in staging/production.
SESSION_COOKIE_SECURE=false
# Idle session lifetime (ISO-8601 duration).
SESSION_TIMEOUT=PT8H

# ── Authentication (session login throttling, NIMBA-9B) ─────────────────────
# Max failed attempts per email and per source IP within the rolling window.
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_WINDOW=PT15M

# ── Observability ───────────────────────────────────────────────────────────
# Actuator endpoints exposed over HTTP. Keep this minimal in production.
ACTUATOR_EXPOSED_ENDPOINTS=health,info

# ── Account provisioning (NIMBA-35) ─────────────────────────────────────────
# There is NO seeding. Create the first admin once via the public bootstrap
# (POST /api/v1/auth/bootstrap, or the /bootstrap page); it self-disables after.
# That admin then provisions everyone else (invitations with a set-password link).
# Public origin of the frontend, used to build the set-password link in e-mails.
APP_FRONTEND_BASE_URL=http://localhost:3000
# How long an invitation stays valid (ISO-8601 duration).
INVITATION_TTL=P7D

# ── E-mail (invitations) ─────────────────────────────────────────────────────
# When false, invitations are still created but no e-mail is sent (grab the link
# from the API/logs instead).
MAIL_ENABLED=true
# Transport: `smtp` (local Mailpit or any SMTP relay) or `resend` (HTTPS API, for
# hosts that block outbound SMTP such as Render). In production on Render use
# `resend`.
MAIL_TRANSPORT=smtp
# SMTP settings (used when MAIL_TRANSPORT=smtp). MAIL_PORT is the SINGLE shared
# variable: the app dials it AND docker-compose exposes Mailpit on it (mirrors the
# POSTGRES_PORT pattern).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
# Fallback sender used until an admin sets the organisation's own sender on the
# org-settings screen. In production set this to an address on your provider-verified
# domain, e.g. no-reply@contact.mrvin100.de (any local-part works once the domain is
# verified — no mailbox required). The display name is MAIL_FROM_NAME.
MAIL_FROM=no-reply@nimba.local
MAIL_FROM_NAME=Nimba
# Resend settings (used when MAIL_TRANSPORT=resend). Get the key from the Resend
# dashboard (API Keys); the organisation sender e-mail must be on a verified
# Resend domain. Never commit the real key.
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Browser origin(s) allowed to call the API (comma-separated for several). Locally
# the frontend is same-origin; set this to the deployed frontend origin(s) in
# staging/production, e.g. https://nimba-web.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# MinIO (object storage for avatars). Endpoint the app connects to; the container
# is reached on the host-mapped API port.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=nimba
MINIO_ROOT_PASSWORD=nimba-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=nimba

# Mailpit web UI port (local dev only).
MAILPIT_UI_PORT=8025
